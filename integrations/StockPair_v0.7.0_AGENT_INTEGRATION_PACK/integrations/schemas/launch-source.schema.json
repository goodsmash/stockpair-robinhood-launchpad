{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockpair.example/schemas/launch-source.schema.json",
  "title": "StockPair Launch Source",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "adapter", "chainId", "enabled", "addresses", "trust"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$" },
    "adapter": {
      "enum": [
        "stockpair-factory",
        "generic-contract-creation",
        "uniswap-v2-factory",
        "uniswap-v3-factory",
        "uniswap-v4-pool-manager",
        "constant-product-bonding-curve",
        "liquidity-bootstrapping-pool"
      ]
    },
    "chainId": { "type": "integer", "minimum": 1 },
    "enabled": { "type": "boolean" },
    "addresses": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" } },
    "trust": { "type": "object", "additionalProperties": true }
  }
}
