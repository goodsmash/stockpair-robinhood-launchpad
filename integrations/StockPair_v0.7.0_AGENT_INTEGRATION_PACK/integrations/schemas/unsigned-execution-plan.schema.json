{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockpair.example/schemas/unsigned-execution-plan.schema.json",
  "title": "StockPair unsigned execution plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "status", "chainId", "candidateId", "createdAt", "expiresAt", "policy", "steps", "authorization"],
  "properties": {
    "version": { "const": "1.0" },
    "status": { "enum": ["draft", "blocked", "ready-for-user-review"] },
    "chainId": { "type": "integer", "minimum": 1 },
    "candidateId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directChainRefresh", "simulation", "verifiedFactory", "maxSlippageBps", "maxPositionBps"],
      "properties": {
        "directChainRefresh": { "const": true },
        "simulation": { "const": true },
        "verifiedFactory": { "const": true },
        "maxSlippageBps": { "type": "integer", "minimum": 1, "maximum": 300 },
        "maxPositionBps": { "type": "integer", "minimum": 1, "maximum": 500 },
        "maxSpend": { "type": "string", "pattern": "^[0-9]+$" }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "state", "evidence"],
        "properties": {
          "kind": { "enum": ["refresh", "provenance", "quote", "simulation", "allowance-review", "transaction-review"] },
          "state": { "enum": ["pending", "passed", "blocked"] },
          "evidence": { "type": "array", "maxItems": 50, "items": { "type": "string", "maxLength": 500 } }
        }
      }
    },
    "transaction": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "to": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
        "value": { "type": "string", "pattern": "^[0-9]+$" },
        "data": { "type": "string", "pattern": "^0x[0-9a-fA-F]*$", "maxLength": 200000 },
        "function": { "type": "string", "maxLength": 200 }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["userSignatureRequired", "privateKeyIncluded", "broadcastAllowed"],
      "properties": {
        "userSignatureRequired": { "const": true },
        "privateKeyIncluded": { "const": false },
        "broadcastAllowed": { "const": false }
      }
    },
    "blockers": { "type": "array", "maxItems": 100, "items": { "type": "string", "maxLength": 500 } }
  }
}
