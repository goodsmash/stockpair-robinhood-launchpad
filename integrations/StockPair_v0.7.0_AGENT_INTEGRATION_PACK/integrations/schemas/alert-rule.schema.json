{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockpair.example/schemas/alert-rule.schema.json",
  "title": "StockPair Launch Alert Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "actions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,79}$" },
    "enabled": { "type": "boolean", "default": true },
    "chainIds": { "type": "array", "maxItems": 32, "items": { "type": "integer", "minimum": 1 }, "uniqueItems": true },
    "symbols": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 32 }, "uniqueItems": true },
    "minScore": { "type": "number", "minimum": 0, "maximum": 100 },
    "maxRiskScore": { "type": "number", "minimum": 0, "maximum": 100 },
    "minVerifiedPools": { "type": "integer", "minimum": 0, "maximum": 100 },
    "minSwaps": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "maxAgeMinutes": { "type": "integer", "minimum": 1, "maximum": 525600 },
    "requirePublicEvidence": { "type": "boolean" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "enum": ["ui", "webhook", "email", "discord", "telegram"] }
    }
  }
}
