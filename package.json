{
  "name": "robinhood-stock-pair-launchpad",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "test:math": "node --test scripts/amm-property.test.mjs",
    "test:static": "node scripts/static-audit.mjs",
    "test:config": "node scripts/validate-config.mjs config/robinhood-testnet.example.json",
    "test": "npm run test:quick",
    "test:structure": "node scripts/solidity-structure-check.mjs",
    "compile": "node scripts/compile-contracts.mjs && node scripts/generate-web-abi.mjs",
    "test:e2e": "npm run compile && node --test --test-concurrency=5 scripts/e2e/*.test.mjs",
    "test:scanner": "node --test scripts/risk-scanner.test.mjs",
    "test:web": "npm --prefix apps/web run build",
    "dev:indexer": "node services/indexer/src/server.mjs",
    "demo": "npm run validate:artifacts && node scripts/start-demo.mjs",
    "demo:fund": "node scripts/fund-local-wallet.mjs",
    "test:quick": "npm run validate:artifacts && npm run test:math && npm run test:structure && npm run test:static && npm run test:config && npm run test:scanner && npm run test:scout && npm run test:indexer-security && npm run test:ui && npm run test:web",
    "test:e2e:lifecycle": "npm run compile && node --test scripts/e2e/lifecycle.test.mjs",
    "test:e2e:creator-bounds": "npm run compile && node --test scripts/e2e/creator-bounds.test.mjs",
    "test:e2e:fee-token": "npm run compile && node --test scripts/e2e/fee-token.test.mjs",
    "test:e2e:reentrancy": "npm run compile && node --test scripts/e2e/reentrancy.test.mjs",
    "test:e2e:oracle": "npm run compile && node --test scripts/e2e/oracle.test.mjs",
    "test:all": "npm test && npm run test:e2e",
    "test:scout": "node --test scripts/scout.test.mjs",
    "test:e2e:security-timelock": "npm run compile && node --test --test-name-pattern='timelock is mandatory' scripts/e2e/security-hardening.test.mjs",
    "test:e2e:security-assets": "npm run compile && node --test --test-name-pattern='strict stock policy' scripts/e2e/security-hardening.test.mjs",
    "test:e2e:security-controls": "npm run compile && node --test --test-name-pattern='creator vesting' scripts/e2e/security-hardening.test.mjs",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "test:e2e:incident-exit": "npm run compile && node --test scripts/e2e/incident-exit.test.mjs",
    "test:e2e:delist-exit": "npm run compile && node --test scripts/e2e/delist-exit.test.mjs",
    "test:e2e:bytecode-policy": "npm run compile && node --test scripts/e2e/bytecode-policy.test.mjs",
    "setup": "node scripts/setup-local.mjs",
    "local": "npm run demo",
    "build:web": "npm --prefix apps/web run build",
    "test:ui": "npm --prefix apps/web run test:ui",
    "check:release": "node scripts/check-release.mjs",
    "verify": "npm run test:quick && npm run check:release",
    "validate:artifacts": "node scripts/validate-artifacts.mjs",
    "demo:fresh": "npm run compile && node scripts/start-demo.mjs",
    "local:fresh": "npm run demo:fresh",
    "test:e2e:frontend-compromise": "npm run compile && node --test scripts/e2e/frontend-compromise.test.mjs",
    "test:e2e:eligibility": "npm run compile && node --test scripts/e2e/eligibility-governance.test.mjs",
    "test:indexer-security": "node --test scripts/indexer-security.test.mjs",
    "generate:web-abi": "node scripts/generate-web-abi.mjs"
  },
  "devDependencies": {
    "ganache": "^7.9.2",
    "solc": "^0.8.36"
  },
  "dependencies": {
    "@stockpair/launch-intelligence-sdk": "file:packages/launch-intelligence-sdk/package",
    "viem": "^2.55.4"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
